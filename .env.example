# ==========================================
# Common Security Credentials
# ==========================================
EUREKA_USER=admin
EUREKA_PASSWORD=1234
GATEWAY_USER=admin
GATEWAY_PASSWORD=1234

# ==========================================
# Service API Keys
# ==========================================
# Google Gemini API Key (Required for AI Code Review Hooks)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Public Data Portal Service Key (Decoding Key recommended)
DATA_GO_SERVICE_KEY=YOUR_SERVICE_KEY

# DART (FSS) API Key
DART_API_KEY=YOUR_API_KEY

# ==========================================
# Telegram Bot Settings (Phase 5)
# ==========================================
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID
TELEGRAM_BOT_NAME=YOUR_BOT_NAME

# ==========================================
# AI/LLM Settings (Phase 5)
# ==========================================
# Spring AI support (Gemini)
SPRING_AI_GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GOOGLE_CLOUD_PROJECT_ID=YOUR_PROJECT_ID
GOOGLE_CLOUD_LOCATION=us-central1

# ==========================================
# Database Connection (Local Defaults)
# ==========================================
# Note: Each service uses its own DB URL.
# If running services locally, ensure ports match docker-compose (3306, 3307, 3308).

# ==========================================
# Database Credentials
# ==========================================
MYSQL_ROOT_PASSWORD=root

# stock-corp
CORP_DB_USER=corp_user
CORP_DB_PASSWORD=corp_pass

# stock-finance
FINANCE_DB_USER=finance_user
FINANCE_DB_PASSWORD=finance_pass

# stock-price
PRICE_DB_USER=price_user
PRICE_DB_PASSWORD=price_pass

# stock-batch
BATCH_DB_USER=batch_user
BATCH_DB_PASSWORD=batch_pass

# stock-strategy
STRATEGY_DB_USER=strategy_user
STRATEGY_DB_PASSWORD=strategy_pass

# stock-ai (Phase 5 - PostgreSQL)
AI_DB_USER=ai_user
AI_DB_PASSWORD=ai_pass
STOCK_AI_DB_URL=jdbc:postgresql://localhost:5435/stock_ai?useSSL=false

# stock-finance
STOCK_FINANCE_DB_URL=jdbc:mysql://localhost:3307/stock_finance?serverTimezone=Asia/Seoul&characterEncoding=UTF-8

# stock-price
STOCK_PRICE_DB_URL=jdbc:mysql://localhost:3308/stock_price?serverTimezone=Asia/Seoul&characterEncoding=UTF-8

# stock-batch (Shared)
STOCK_BATCH_DB_URL=jdbc:mysql://localhost:3309/stock_batch?serverTimezone=Asia/Seoul&characterEncoding=UTF-8

# stock-strategy
STOCK_STRATEGY_DB_URL=jdbc:mysql://localhost:3310/stock_strategy?serverTimezone=Asia/Seoul&characterEncoding=UTF-8

# ==========================================
# Redis Credentials
# ==========================================
REDIS_PASSWORD=redis_pass