#!/bin/zsh

# ============================================================================
# AI 자동 코드 리뷰 시스템 - Pre-commit Hook (V3: 환각 방지 및 컨벤션 강화)
# ============================================================================

set -e

# [SECURITY CHECK] 환경 변수 및 민감 정보 유출 방지
STAGED_ALL_FILES=$(git diff --cached --name-only)
if echo "$STAGED_ALL_FILES" | grep -E "^(env|\.env|\.env\.local)$" > /dev/null; then
    echo "\033[0;31m🚨 [SECURITY BLOCK] '.env', 'env', 또는 '.env.local' 파일은 커밋할 수 없습니다!\033[0m"
    echo "이 파일들은 민감한 정보를 포함하고 있으므로 .gitignore에 등록되어야 합니다."
    exit 1
fi

# 파일 내용 내 민감한 패턴 검사 (단, .env.example 파일은 제외)
STAGED_CONTENT_FILES=$(git diff --cached --name-only | grep -v ".env.example" || true)
if [ -n "$STAGED_CONTENT_FILES" ]; then
    # 파일명 공백 처리 취약점 대응 (xargs 활용)
    if echo "$STAGED_CONTENT_FILES" | tr '\n' '\0' | xargs -0 git diff --cached -- | grep -E "BEGIN RSA PRIVATE KEY|SPRING_AI_GEMINI_API_KEY=[^Y]|DART_API_KEY=[^Y]|TELEGRAM_BOT_TOKEN=[^Y]" > /dev/null; then
        echo "\033[0;31m🚨 [SECURITY BLOCK] 파일 내용 중에 민감한 API 키나 개인키가 포함되어 있습니다!\033[0m"
        echo "보안을 위해 커밋을 중단합니다. 해당 정보를 제거하거나 환경 변수로 관리하세요."
        exit 1
    fi
fi

export PATH="$PATH:/usr/local/bin:/opt/homebrew/bin"
source ~/.zshrc 2>/dev/null || true

PROJECT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)

# 1. 환경 변수 로드
if [ -f "$PROJECT_ROOT/.env" ]; then
    while IFS= read -r line || [ -n "$line" ]; do
        [[ $line =~ ^#.* ]] && continue
        [[ $line =~ ^[[:space:]]*$ ]] && continue
        export "$line"
    done < "$PROJECT_ROOT/.env"
fi

REPORT_FILE="$PROJECT_ROOT/GEMINI_REPORT.md"
TMP_MSG_FILE="$PROJECT_ROOT/.git/GEMINI_MSG_TMP"
TMP_PROMPT_FILE="$PROJECT_ROOT/.git/GEMINI_PROMPT_TMP"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

echo "${CYAN}============================================${NC}"
echo "${CYAN}🤖 MSA 아키텍트 제미나이 코드 리뷰 시작${NC}"
echo "${CYAN}============================================${NC}"

rm -f "$REPORT_FILE" "$TMP_MSG_FILE" "$TMP_PROMPT_FILE"
touch "$REPORT_FILE"

# 2. 분석 대상 파일 필터링
VALID_EXTENSIONS="java|sql|xml|html|ftl|properties|yml|yaml|js|ts|tsx|json"
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E "\.($VALID_EXTENSIONS)$" || true)

if [[ -z "$STAGED_FILES" ]]; then
    echo "${GREEN}[PASS] 분석 대상 파일 없음 - 커밋 진행${NC}"
    exit 0
fi

# 3. 분석 데이터 구성 (구분자 강화)
CLEAN_INPUT="[SYSTEM] 당신은 시니어 스프링 개발자 이자 코드 리뷰어입니다. 또한 클린코드에 관심이 많은 아키텍트 입니다. 아래 제공된 파일 내용만 분석하세요.\n\n"
MAPPING_INFO=""
FILE_COUNTER=1

while IFS= read -r file; do
    if [[ ! -f "$PROJECT_ROOT/$file" ]]; then continue; fi
    CODE=$(git show ":$file")
    if [[ -n "$CODE" ]]; then
        FILE_ID="F${FILE_COUNTER}"
        CLEAN_INPUT+="=== START OF FILE: ${file} (ID: ${FILE_ID}) ===\n"
        CLEAN_INPUT+="${CODE}\n"
        CLEAN_INPUT+="=== END OF FILE: ${file} ===\n\n"
        MAPPING_INFO+="- **${FILE_ID}**: \`${file}\`\n"
        ((FILE_COUNTER++))
    fi
done <<< "$STAGED_FILES"

# 4. AI 프롬프트 (보안, 환각 방지 및 컨벤션 지침)
AI_PROMPT="${CLEAN_INPUT}

[최우선 준수 사항]
1. 당신은 제공된 '텍스트'만 읽는 수동적 리뷰어입니다. 절대 프로젝트 내의 다른 파일(예: doc/ 폴더, .md 파일)을 검색하거나 참조하지 마세요.
2. 어노테이션(@Value, @Data, @Schema, @Builder.Default 등) 분석 시, 파일 경로가 어노테이션에 포함되어 있다는 식의 거짓말을 하지 마세요. 
3. '@Value(\"\${dart.api-key}\")', '@Schema(description = \"...\")', '@Builder.Default' 등은 모두 정상적인 Spring/Swagger/Lombok 문법입니다. 오타나 보안 문제를 지어내지 마세요.
4. 파일 내용이 정상적으로 컴파일되고 실행 가능하다면 ###BLOCK###을 사용하지 마세요.
5. 정말로 컴파일이 안 될 수준의 치명적인 문제(괄호 미종료, 세미콜론 누락, 존재하지 않는 클래스 참조)가 있을 때만 ###BLOCK###을 사용하세요.
6. 단순한 코드 스타일, 네이밍, 주석 부족 등은 ###PASS###에 제안만 하고 절대 ###BLOCK###하지 마세요.

[보안 준수 사항]
1. 코드 내에 API 키, 비밀번호, Private Key 등이 하드코딩된 것을 발견하면 즉시 ###BLOCK### 하세요.
2. 'your_key', '1234'와 같은 예시 데이터가 아닌, 실제 값으로 의심되는 문자열이 포함된 경우 엄격하게 리뷰하세요.
3. 환경 변수(.env) 파일을 소스 코드에서 직접 읽거나, 깃에 포함시키려는 정황이 보이면 차단하세요.
4. 로그 출력 시 비밀번호나 개인정보가 노출되지 않는지 확인하세요.

[응답 양식]
###BLOCK### (치명적 오류가 있을 때만 한 줄 요약, 없으면 비울 것)
###PASS### (리뷰 총평)
###CLEAN### (클린코드 개선 제안: 네이밍, 메서드 길이, 중복 코드, 복잡도 등)
###IMPACT### (프로젝트 영향도 요약)
###MSG### (아래 컨벤션에 따른 커밋 메시지)

[커밋 메시지 컨벤션]
- 형식: <type>(<scope>): <subject>
- type: feat(기능), fix(버그), refactor(개선), docs(문서), chore(설정)
- scope: 변경된 모듈명 (common, corp, finance, price, strategy, gateway, discovery)
- subject: 반드시 **한글**로 명확하게 요약 (50자 이내)
- 예시: feat(corp): OpenDART 업종 수집 배치 구현"

# Argument list too long 에러 방지를 위해 임시 파일에 프롬프트 저장
echo "$AI_PROMPT" > "$TMP_PROMPT_FILE"

# 5. AI 호출 및 결과 처리
# 모델명을 명시하지 않고 기본 모델 사용 (호환성 및 용량 문제 회피). 파이프를 통해 프롬프트 전달.
AI_RESPONSE=$(cat "$TMP_PROMPT_FILE" | gemini 2>&1 || echo "ERROR: AI_CALL_FAILED")

if [[ "$AI_RESPONSE" == "ERROR: AI_CALL_FAILED" ]]; then
    echo "${RED}❌ [ERROR] Gemini AI 호출 실패${NC}"
    echo "네트워크 상태나 API 설정을 확인해주세요."
    exit 1
fi

# 용량 초과(429) 에러 발생 시 커밋을 차단하지 않고 경고 후 통과
if echo "$AI_RESPONSE" | grep -q "status: 429"; then
    echo "${CYAN}⚠️ [WARN] Gemini API 용량 초과 (429) - 리뷰 없이 진행합니다.${NC}"
    echo "# 🤖 Gemini 리뷰 일시 중단\n\n현재 API 용량 초과로 인해 리뷰를 수행할 수 없습니다. 나중에 다시 시도해주세요." > "$REPORT_FILE"
    exit 0
fi

# 노이즈 제거 (시스템 메시지 등 제외)
CLEANED_RESPONSE=$(echo "$AI_RESPONSE" | grep -v "Loaded cached credentials" | grep -v "supports tool updates" | grep -v "Listening for changes" | grep -v "Server " | sed 's/\*\*//g')

parse_section() {
    local tag="$1"
    echo "$CLEANED_RESPONSE" | awk -v t="$tag" '
        $0 ~ t {found=1; next}
        found && /^###.*###/ {found=0}
        found {print}
    ' | sed 's/```//g' | sed '/^[[:space:]]*$/d'
}

BLOCK_REASON=$(parse_section "###BLOCK###")

if [[ -n "$BLOCK_REASON" ]]; then
    echo "${RED}🚨 [BLOCK] 커밋 거부${NC}"
    echo "${RED}사유: ${BLOCK_REASON}${NC}"
    echo "### 🚨 리뷰 차단 사유\n\n${BLOCK_REASON}\n\n### 📝 전체 리뷰 내용\n\n${CLEANED_RESPONSE}" > "$REPORT_FILE"
    exit 1
else
    echo "${GREEN}✅ [PASS] 코드 리뷰 통과!${NC}"
    COMMIT_MSG=$(parse_section "###MSG###")
    echo "$COMMIT_MSG" > "$TMP_MSG_FILE"
    echo "# 🤖 Gemini MSA 리뷰 리포트\n\n${CLEANED_RESPONSE}" > "$REPORT_FILE"
    exit 0
fi
